---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MSKÜ Teknoloji ve Mühendislik Topluluğu">
  <main class="min-h-screen flex flex-col items-center justify-center p-6 relative overflow-hidden">
    
    <!-- Background Decor (Color Glows mapping to logo colors: deep purple, cyan, warm amber, pink) -->
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-cyan-600/30 rounded-full blur-[100px] -z-10 pointer-events-none"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-purple-600/30 rounded-full blur-[100px] -z-10 pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg h-96 bg-amber-500/20 rounded-full blur-[100px] -z-10 pointer-events-none"></div>

    <div class="w-full max-w-md flex flex-col items-center z-10">
      
      <!-- Profile / Logo Section -->
      <div class="mb-8 flex flex-col items-center animate-fade-in-down">
        <!-- Replace src with your actual logo path -->
        <div class="relative group">
          <div class="absolute -inset-1 bg-gradient-to-r from-purple-600 via-pink-500 to-amber-500 rounded-full blur opacity-75 group-hover:opacity-100 transition duration-1000 group-hover:duration-200"></div>
          <img 
            src="/logo.png" 
            alt="MSKÜ Logo" 
            class="relative w-36 h-36 rounded-full object-cover border-4 border-slate-900 shadow-[0_0_20px_rgba(0,0,0,0.5)]"
          />
        </div>
        <h1 class="mt-6 text-2xl md:text-3xl font-bold font-['Outfit'] text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-purple-300 to-pink-300 text-center tracking-wide">
          Teknoloji ve <br/> Mühendislik Topluluğu
        </h1>
        <p class="mt-2 text-slate-300 font-medium tracking-widest uppercase text-sm">
          MSKÜ
        </p>
      </div>

      <!-- Links/Buttons Section -->
      <div class="w-full flex flex-col gap-4 animate-fade-in-up" style="animation-delay: 0.1s; animation-fill-mode: both;">
        
        <!-- Instagram Button -->
        <a href="https://www.instagram.com/tmt_msku/" target="_blank" rel="noopener noreferrer" class="group relative w-full flex items-center p-4 rounded-xl overflow-hidden backdrop-blur-md bg-white/5 border border-white/10 hover:bg-white/10 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] hover:shadow-[0_0_30px_rgba(245,158,11,0.2)]">
          <div class="absolute inset-0 bg-gradient-to-r from-amber-500/0 via-pink-500/0 to-purple-600/0 group-hover:from-amber-500/10 group-hover:via-pink-500/10 group-hover:to-purple-600/10 transition-all duration-500 ease-out"></div>
          <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-gradient-to-tr from-amber-500 via-pink-500 to-purple-600 text-white shrink-0 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
          </div>
          <span class="ml-4 text-slate-100 font-semibold text-lg flex-1 group-hover:text-white transition-colors duration-300 pt-0.5">Instagram</span>
          <div class="text-white/30 group-hover:text-pink-400 transition-colors duration-300 group-hover:translate-x-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m9 18 6-6-6-6"/></svg>
          </div>
        </a>

        <!-- WhatsApp Button -->
        <a href="https://chat.whatsapp.com/BAlWJBHf6cB5vfVhgVXXv6?mode=gi_t" target="_blank" rel="noopener noreferrer" class="group relative w-full flex items-center p-4 rounded-xl overflow-hidden backdrop-blur-md bg-white/5 border border-white/10 hover:bg-white/10 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] hover:shadow-[0_0_30px_rgba(6,182,212,0.2)]">
          <div class="absolute inset-0 bg-gradient-to-r from-teal-500/0 via-cyan-500/0 to-blue-500/0 group-hover:from-teal-500/10 group-hover:via-cyan-500/10 group-hover:to-blue-500/10 transition-all duration-500 ease-out"></div>
          <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-gradient-to-tr from-teal-400 to-cyan-500 text-white shrink-0 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <span class="ml-4 text-slate-100 font-semibold text-lg flex-1 group-hover:text-white transition-colors duration-300 pt-0.5">WhatsApp</span>
          <div class="text-white/30 group-hover:text-cyan-400 transition-colors duration-300 group-hover:translate-x-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m9 18 6-6-6-6"/></svg>
          </div>
        </a>

        <!-- Toplulukta Görev Al Button -->
        <a href="https://forms.gle/sKtTDdsfJcBjn4Bv8" target="_blank" rel="noopener noreferrer" class="group relative w-full flex items-center p-4 rounded-xl overflow-hidden backdrop-blur-md bg-white/5 border border-white/10 hover:bg-white/10 transition-all duration-300 hover:scale-[1.02] active:scale-[0.98] hover:shadow-[0_0_30px_rgba(147,51,234,0.2)]">
          <div class="absolute inset-0 bg-gradient-to-r from-purple-600/0 via-indigo-500/0 to-cyan-500/0 group-hover:from-purple-600/10 group-hover:via-indigo-500/10 group-hover:to-cyan-500/10 transition-all duration-500 ease-out"></div>
          <div class="flex items-center justify-center w-12 h-12 rounded-lg bg-gradient-to-tr from-purple-600 to-indigo-500 text-white shrink-0 shadow-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
          </div>
          <span class="ml-4 text-slate-100 font-semibold text-lg flex-1 group-hover:text-white transition-colors duration-300 pt-0.5">Toplulukta Görev Al</span>
          <div class="text-white/30 group-hover:text-indigo-400 transition-colors duration-300 group-hover:translate-x-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="m9 18 6-6-6-6"/></svg>
          </div>
        </a>

      </div>
      
      <!-- Footer Note -->
      <footer class="mt-12 text-slate-400/60 text-sm font-medium animate-fade-in-up" style="animation-delay: 0.2s; animation-fill-mode: both;">
        <p>&copy; {new Date().getFullYear()} MSKÜ Teknoloji ve Mühendislik Topluluğu</p>
      </footer>
    </div>
  </main>
</Layout>

<style>
  /* Custom utility classes for animations that are small enough to keep inline */
  @keyframes fade-in-down {
    0% {
      opacity: 0;
      transform: translateY(-20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  @keyframes fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-down {
    animation: fade-in-down 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  .animate-fade-in-up {
    animation: fade-in-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
